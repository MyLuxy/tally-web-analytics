# Copy this to .env and fill it in before running docker compose.

# The hostname Caddy will request an HTTPS certificate for and serve Tally on.
# With a free DuckDNS subdomain this looks like: mysite.duckdns.org
TALLY_DOMAIN=your-subdomain.duckdns.org

# Optional. Leave empty to keep the dashboard open; set a long random string to
# require it as a bearer token on the stats API (the /api/collect endpoint stays
# open either way).
TALLY_TOKEN=
