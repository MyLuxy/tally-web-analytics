# Copy this to .env and fill it in before running docker compose.

# Optional. Leave empty to keep the dashboard open; set a long random string to
# require it as a bearer token on the stats API (the /api/collect endpoint stays
# open either way).
TALLY_TOKEN=

# Localhost port the Tally container is published on. Your existing reverse
# proxy points at http://127.0.0.1:<this>. Change it if 3000 is already in use.
TALLY_HOST_PORT=3000

# Only used with the bundled Caddy (the "caddy" profile). It's the hostname Caddy
# requests an HTTPS certificate for. Ignore it if you're using your own proxy.
TALLY_DOMAIN=your-subdomain.duckdns.org
